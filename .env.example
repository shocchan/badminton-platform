VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxx

# Stripe クレジット決済（未設定の場合、申し込みフォームにクレジットの選択肢は表示されない）
# テスト: pk_test_... / 本番: pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ※ シークレットキー（sk_...）はフロントの .env に置かず、Supabase Edge Functions の secrets に設定する:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_xxxxx --project-ref <project-ref>
