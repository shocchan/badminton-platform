{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash",
      "Fetch",
      "Write(src/**)",
      "Write(components/**)",
      "Write(public/**)",
      "Write(pages/**)",
      "Write(lib/**)",
      "Write(styles/**)",
      "Write(utils/**)",
      "Write(supabase/**)",
      "Write(.env.local)",
      "Write(.env.example)",
      "Read"
    ],
    "ask": [
      "Bash(*stripe*)",
      "Bash(*payment*)",
      "Bash(*paypal*)",
      "Bash(*charge*)",
      "Bash(*billing*)",
      "Fetch(*stripe*)",
      "Fetch(*payment*)"
    ],
    "deny": [
      "Bash(./scripts/deploy-production.sh)",
      "Bash(bash scripts/deploy-production.sh)",
      "Bash(sh scripts/deploy-production.sh)",
      "Bash(wrangler pages deploy --branch=main)",
      "Bash(supabase functions deploy)",
      "Write(.env.production)",
      "Write(.env.production.local)",
      "Write(.npmrc)",
      "Write(secret:*)"
    ]
  }
}
